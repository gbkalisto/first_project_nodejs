<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Intelligence | Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="icon" type="image/svg+xml"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='%230d6efd' class='bi bi-stack' viewBox='0 0 16 16'><path d='m14.12 10.163 1.715.858c.22.11.22.424 0 .534L8.267 15.34a.6.6 0 0 1-.534 0L.165 11.555a.299.299 0 0 1 0-.534l1.716-.858 5.317 2.659c.505.252 1.1.252 1.604 0l5.317-2.66zM7.733.063a.6.6 0 0 1 .534 0l7.568 3.784a.3.3 0 0 1 0 .535L8.267 8.165a.6.6 0 0 1-.534 0L.165 4.382a.299.299 0 0 1 0-.535z'/><path d='m14.12 6.576 1.715.858c.22.11.22.424 0 .534l-7.568 3.784a.6.6 0 0 1-.534 0L.165 7.968a.299.299 0 0 1 0-.534l1.716-.858 5.317 2.659c.505.252 1.1.252 1.604 0z'/></svg>">

    <link rel="stylesheet" href="/css/admin/style.css">


</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/admin/dashboard">
                <div class="bg-primary p-1 rounded-2 d-inline-flex">
                    <i class="bi bi-layers-half text-white"></i>
                </div>
                <span>CORE<span class="fw-light text-secondary">ADMIN</span></span>
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse"
                data-bs-target="#mainMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainMenu">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/posts">Posts</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/categories">Categories</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="inventoryLink" data-bs-toggle="dropdown">
                            Inventory
                        </a>
                        <ul class="dropdown-menu shadow-lg border-0">
                            <li><a class="dropdown-item" href="/admin/products">All Products</a></li>
                            <li><a class="dropdown-item" href="/admin/products/create">Create New</a></li>
                            <!-- <li>
                                <hr class="dropdown-divider opacity-50">
                            </li> -->
                            <!-- <li><a class="dropdown-item" href="/analytics">Stock Analytics</a></li> -->
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/admin/users">Users</a>
                    </li>
                </ul>

                <div class="d-flex align-items-center">
                    <div class="dropdown">
                        <!-- <div class="user-profile-btn dropdown-toggle" role="button" data-bs-toggle="dropdown">
                            <div class="avatar-circle">
                                <%= admin.name.charAt(0).toUpperCase() %>
                            </div>
                            <span class="small fw-medium d-none d-md-block">
                                <%= admin.name %>
                            </span>
                        </div> -->
                        <div class="user-profile-btn dropdown-toggle" role="button" data-bs-toggle="dropdown">
                            <div class="avatar-circle overflow-hidden d-flex align-items-center justify-content-center">
                                <% if (admin.image && admin.image !=='default-profile.png' ) { %>
                                    <img src="/<%= admin.image %>" alt="<%= admin.name %>"
                                        style="width: 100%; height: 100%; object-fit: cover;">
                                    <% } else { %>
                                        <%= admin.name.charAt(0).toUpperCase() %>
                                            <% } %>
                            </div>

                            <span class="small fw-medium d-none d-md-block ms-2">
                                <%= admin.name %>
                            </span>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end mt-3 border-0 shadow-lg">
                            <li class="px-3 py-2 small text-muted fw-bold text-uppercase">Admin Account</li>
                            <li><a class="dropdown-item" href="/admin/profile"><i class="bi bi-person me-2"></i> My
                                    Profile</a></li>
                            <li><a class="dropdown-item" href="/settings"><i class="bi bi-sliders me-2"></i>
                                    Settings</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item text-danger" href="/admin/logout"><i
                                        class="bi bi-box-arrow-right me-2"></i> Sign Out</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>