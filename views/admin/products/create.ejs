<%- include('../partials/header') %>

<main class="main-content">
    <header class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item small"><a href="/admin/dashboard" class="text-decoration-none text-muted">Console</a></li>
                    <li class="breadcrumb-item small"><a href="/admin/products" class="text-decoration-none text-muted">Products</a></li>
                    <li class="breadcrumb-item small active">Add New</li>
                </ol>
            </nav>
            <h2 class="fw-bold tracking-tight">Add New Product</h2>
        </div>
        <div>
            <a href="/admin/products" class="btn btn-white border bg-white shadow-sm btn-sm px-3 py-2 fw-semibold">
                <i class="bi bi-arrow-left me-1"></i> Back to Inventory
            </a>
        </div>
    </header>

    <form action="/admin/products" method="POST" enctype="multipart/form-data">
        <div class="row g-4">
            
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">General Information</h5>
                        
                        <div class="mb-4">
                            <label for="name" class="form-label small fw-bold text-muted text-uppercase">Product Title</label>
                            <input type="text" 
                                class="form-control form-control-lg shadow-none <%= (typeof errors !== 'undefined' && errors.name) ? 'is-invalid' : '' %>" 
                                name="name" id="name" placeholder="e.g. Mechanical Gaming Keyboard"
                                value="<%= (typeof oldData !== 'undefined') ? oldData.name : '' %>" required>
                            <% if (typeof errors !== 'undefined' && errors.name) { %>
                                <div class="invalid-feedback"><%= errors.name %></div>
                            <% } %>
                        </div>

                        <div class="mb-0">
                            <label for="description" class="form-label small fw-bold text-muted text-uppercase">Product Description</label>
                            <textarea class="form-control shadow-none" id="description" name="description" rows="10" 
                                placeholder="Describe the product features, materials, and specs..."><%= (typeof oldData !== 'undefined') ? oldData.description : '' %></textarea>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Media</h5>
                        <div class="image-upload-wrapper border-dashed rounded-4 p-5 text-center bg-light" style="border: 2px dashed #cbd5e1;">
                            <div id="preview-container" class="mb-3 d-none">
                                <img id="image-preview" src="#" alt="Preview" class="img-fluid rounded-3 shadow-sm" style="max-height: 250px;">
                            </div>
                            <div id="upload-placeholder">
                                <i class="bi bi-image fs-1 text-muted"></i>
                                <p class="small text-muted mt-2">Upload product main image<br>Recommended size: 800x800px</p>
                            </div>
                            <input type="file" name="image" id="imageInput" class="form-control mt-3 shadow-none" accept="image/*" required>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Organization</h5>
                        
                        <div class="mb-4">
                            <label for="category" class="form-label small fw-bold text-muted text-uppercase">Category</label>
                            <select class="form-select shadow-none <%= (typeof errors !== 'undefined' && errors.category) ? 'is-invalid' : '' %>" 
                                    name="category" id="category" required>
                                <option value="" selected disabled>Select Category</option>
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat.name %>"><%= cat.name %></option>
                                <% }) %>
                            </select>
                            <% if (typeof errors !== 'undefined' && errors.category) { %>
                                <div class="invalid-feedback"><%= errors.category %></div>
                            <% } %>
                        </div>

                        <hr class="my-4 opacity-50">

                        <h5 class="fw-bold mb-4">Pricing & Stock</h5>
                        
                        <div class="mb-4">
                            <label for="price" class="form-label small fw-bold text-muted text-uppercase">Price ($)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">$</span>
                                <input type="number" step="0.01" 
                                    class="form-control shadow-none border-start-0 <%= (typeof errors !== 'undefined' && errors.price) ? 'is-invalid' : '' %>" 
                                    name="price" id="price" placeholder="0.00"
                                    value="<%= (typeof oldData !== 'undefined') ? oldData.price : '' %>" required>
                            </div>
                        </div>

                        <div class="mb-0">
                            <label for="stock" class="form-label small fw-bold text-muted text-uppercase">Stock Quantity</label>
                            <input type="number" class="form-control shadow-none" name="stock" id="stock" placeholder="0" required>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary py-3 fw-bold shadow-sm">
                        <i class="bi bi-cloud-arrow-up me-2"></i> Publish Product
                    </button>
                    <button type="reset" class="btn btn-white border py-2 small fw-semibold">
                        Discard Draft
                    </button>
                </div>
            </div>

        </div>
    </form>
</main>

<script>
    const imageInput = document.getElementById('imageInput');
    const previewContainer = document.getElementById('preview-container');
    const imagePreview = document.getElementById('image-preview');
    const placeholder = document.getElementById('upload-placeholder');

    imageInput.onchange = evt => {
        const [file] = imageInput.files;
        if (file) {
            imagePreview.src = URL.createObjectURL(file);
            previewContainer.classList.remove('d-none');
            placeholder.classList.add('d-none');
        }
    }
</script>

<%- include('../partials/footer') %>