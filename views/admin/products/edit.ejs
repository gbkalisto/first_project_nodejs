<%- include('../partials/header') %>

<main class="main-content">
    <header class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item small"><a href="/admin/dashboard" class="text-decoration-none text-muted">Console</a></li>
                    <li class="breadcrumb-item small"><a href="/admin/products" class="text-decoration-none text-muted">Products</a></li>
                    <li class="breadcrumb-item small active">Edit Mode</li>
                </ol>
            </nav>
            <h2 class="fw-bold tracking-tight">Edit Product</h2>
        </div>
        <div>
            <a href="/admin/products" class="btn btn-white border bg-white shadow-sm btn-sm px-3 py-2 fw-semibold">
                <i class="bi bi-x-lg me-1"></i> Cancel
            </a>
        </div>
    </header>

    <form action="/admin/products/<%= product._id %>?_method=PUT" method="POST" enctype="multipart/form-data">
        <div class="row g-4">
            
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 text-dark">Core Information</h5>
                        
                        <div class="mb-4">
                            <label for="name" class="form-label small fw-bold text-muted text-uppercase">Product Title</label>
                            <input type="text" 
                                class="form-control form-control-lg shadow-none" 
                                name="name" id="name" placeholder="e.g. Wireless Mouse"
                                value="<%= product.name %>" required>
                        </div>

                        <div class="mb-0">
                            <label for="description" class="form-label small fw-bold text-muted text-uppercase">Detailed Description</label>
                            <textarea class="form-control shadow-none" id="description" name="description" rows="10" 
                                placeholder="Edit product details..."><%= product.description %></textarea>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 text-dark">Product Gallery</h5>
                        <div class="image-upload-wrapper border-dashed rounded-4 p-5 text-center bg-light" style="border: 2px dashed #cbd5e1;">
                            
                            <div id="preview-container" class="mb-3">
                                <img id="imagePreview" 
                                     src="/<%= product.image ? product.image : 'images/placeholder.png' %>" 
                                     alt="Current Preview" 
                                     class="img-fluid rounded-3 shadow-sm border bg-white" 
                                     style="max-height: 250px; object-fit: contain;">
                                <p class="x-small text-muted mt-2" id="preview-label">Currently stored image</p>
                            </div>

                            <input type="file" name="image" id="imageInput" 
                                   class="form-control mt-3 shadow-none bg-white border" 
                                   accept="image/*" onchange="updatePreview(event)">
                            <p class="small text-muted mt-2 mb-0">Leave blank to keep the current image.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 text-dark">Classification</h5>
                        
                        <div class="mb-4">
                            <label for="category" class="form-label small fw-bold text-muted text-uppercase">Category</label>
                            <select class="form-select shadow-none" name="category" id="category" required>
                                <option value="" disabled>Change Category</option>
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat.name %>" <%= (product.category === cat.name) ? 'selected' : '' %>>
                                        <%= cat.name %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <hr class="my-4 opacity-50">

                        <h5 class="fw-bold mb-4 text-dark">Pricing & Inventory</h5>
                        
                        <div class="mb-4">
                            <label for="price" class="form-label small fw-bold text-muted text-uppercase">Price ($)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">$</span>
                                <input type="number" step="0.01" 
                                    class="form-control shadow-none border-start-0" 
                                    name="price" id="price" placeholder="0.00"
                                    value="<%= product.price %>" required>
                            </div>
                        </div>

                        <div class="mb-0">
                            <label for="stock" class="form-label small fw-bold text-muted text-uppercase">In-Stock Quantity</label>
                            <input type="number" class="form-control shadow-none" name="stock" id="stock" 
                                   value="<%= product.stock %>" placeholder="0" required>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary py-3 fw-bold shadow-sm">
                        <i class="bi bi-check2-circle me-2"></i> Save Changes
                    </button>
                    <div class="text-center mt-2">
                        <span class="text-muted extra-small">Last modified: <%= new Date().toLocaleDateString() %></span>
                    </div>
                </div>
            </div>

        </div>
    </form>
</main>

<script>
    function updatePreview(event) {
        const preview = document.getElementById('imagePreview');
        const label = document.getElementById('preview-label');
        const file = event.target.files[0];
        
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                label.innerHTML = '<span class="text-primary fw-bold">New image selected (unsaved)</span>';
            }
            reader.readAsDataURL(file);
        }
    }
</script>

<%- include('../partials/footer') %>