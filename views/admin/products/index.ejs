<%- include('../partials/header') %>

<main class="main-content">
    <header class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item small">
                        <a href="/admin/dashboard" class="text-decoration-none text-muted">Console</a>
                    </li>
                    <li class="breadcrumb-item small active">Products</li>
                </ol>
            </nav>
            <h2 class="fw-bold tracking-tight">Product Inventory</h2>
        </div>
        <div class="d-flex gap-2">
            <a href="/admin/products/create" class="btn btn-primary btn-sm px-3 py-2 fw-semibold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Add Product
            </a>
        </div>
    </header>

    <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table align-middle mb-0" style="background: white;">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted small fw-bold text-uppercase">Product</th>
                        <th class="py-3 text-muted small fw-bold text-uppercase">Category</th>
                        <th class="py-3 text-muted small fw-bold text-uppercase">Price</th>
                        <th class="py-3 text-muted small fw-bold text-uppercase">Stock Status</th>
                        <th class="pe-4 py-3 text-muted small fw-bold text-uppercase text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products.length > 0) { %>
                        <% products.forEach(function(product){ %>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-3 border overflow-hidden shadow-sm" style="width: 50px; height: 50px;">
                                            <img src="/<%= product.image %>" 
                                                 alt="<%= product.name %>" 
                                                 class="w-100 h-100 object-fit-cover">
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark"><%= product.name %></div>
                                            <div class="text-muted extra-small" style="font-size: 0.7rem;">ID: <%= product._id.toString().substring(0,8) %>...</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border fw-medium px-2 py-1">
                                        <%= product.category %>
                                    </span>
                                </td>
                                <td>
                                    <span class="fw-bold text-dark">$<%= product.price.toLocaleString() %></span>
                                </td>
                                <td>
                                    <% if(product.stock <= 0) { %>
                                        <div class="d-flex align-items-center gap-2 text-danger small fw-bold">
                                            <i class="bi bi-x-circle-fill"></i> Out of Stock
                                        </div>
                                    <% } else if(product.stock < 10) { %>
                                        <div class="d-flex align-items-center gap-2 text-warning small fw-bold">
                                            <i class="bi bi-exclamation-triangle-fill"></i> Low Stock (<%= product.stock %>)
                                        </div>
                                    <% } else { %>
                                        <div class="d-flex align-items-center gap-2 text-success small fw-bold">
                                            <i class="bi bi-check-circle-fill"></i> <%= product.stock %> in Stock
                                        </div>
                                    <% } %>
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/admin/products/<%= product._id %>/edit" 
                                           class="btn btn-sm btn-white border shadow-sm px-3" 
                                           title="Edit Product">
                                            <i class="bi bi-pencil-square text-primary"></i>
                                        </a>
                                        
                                        <form action="/admin/products/<%= product._id %>?_method=DELETE" 
                                              method="POST" 
                                              onsubmit="return confirm('Remove this product from inventory?');"
                                              class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-white border shadow-sm px-3">
                                                <i class="bi bi-trash3 text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-box-seam fs-1 d-block mb-2 opacity-50"></i>
                                No products found in your inventory.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>