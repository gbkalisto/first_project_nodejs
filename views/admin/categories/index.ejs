<%- include('../partials/header') %>

<main class="main-content">
    <header class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item small">
                        <a href="/admin/dashboard" class="text-decoration-none text-muted">Console</a>
                    </li>
                    <li class="breadcrumb-item small active">Categories</li>
                </ol>
            </nav>
            <h2 class="fw-bold tracking-tight">Category Management</h2>
        </div>
        <div class="d-flex gap-2">
            <a href="/admin/categories/create" class="btn btn-primary btn-sm px-3 py-2 fw-semibold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Add Category
            </a>
        </div>
    </header>

    <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table align-middle mb-0" style="background: white;">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted small fw-bold text-uppercase">Preview</th>
                        <th class="py-3 text-muted small fw-bold text-uppercase">Name & Slug</th>
                        <th class="py-3 text-muted small fw-bold text-uppercase">Description</th>
                        <th class="py-3 text-muted small fw-bold text-uppercase text-center">Status</th>
                        <th class="pe-4 py-3 text-muted small fw-bold text-uppercase text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (categories.length > 0) { %>
                        <% categories.forEach(function(category){ %>
                            <tr>
                                <td class="ps-4">
                                    <div class="rounded-3 border overflow-hidden" style="width: 56px; height: 56px;">
                                        <img src="/<%= category.image %>" 
                                             alt="<%= category.name %>" 
                                             class="w-100 h-100 object-fit-cover">
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark"><%= category.name %></div>
                                    <div class="text-muted extra-small" style="font-size: 0.75rem;"><%= category.slug %></div>
                                </td>
                                <td class="text-muted small">
                                    <%= category.description.length > 50 ? category.description.substring(0, 50) + '...' : category.description %>
                                </td>
                                <td class="text-center">
                                    <% if(category.is_active) { %>
                                        <span class="badge rounded-pill px-3 py-2" style="background: #dcfce7; color: #166534; font-weight: 600;">Active</span>
                                    <% } else { %>
                                        <span class="badge rounded-pill px-3 py-2" style="background: #fee2e2; color: #991b1b; font-weight: 600;">Inactive</span>
                                    <% } %>
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/admin/categories/<%= category._id %>/edit" 
                                           class="btn btn-sm btn-white border shadow-sm px-3" 
                                           title="Edit">
                                            <i class="bi bi-pencil-square text-primary"></i>
                                        </a>
                                        
                                        <form action="/admin/categories/delete/<%= category._id %>?_method=DELETE" 
                                              method="POST" 
                                              onsubmit="return confirm('Are you sure you want to delete this category?');"
                                              class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-white border shadow-sm px-3">
                                                <i class="bi bi-trash3 text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-folder-x fs-1 d-block mb-2"></i>
                                No categories found.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>