<%- include('../partials/header') %>

    <main class="main-content">
        <header class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item small"><a href="/admin/dashboard"
                                class="text-decoration-none text-muted">Console</a></li>
                        <li class="breadcrumb-item small"><a href="/admin/categories"
                                class="text-decoration-none text-muted">Categories</a></li>
                        <li class="breadcrumb-item small active">Add New</li>
                    </ol>
                </nav>
                <h2 class="fw-bold tracking-tight">Create Category</h2>
            </div>
            <div>
                <a href="/admin/categories"
                    class="btn btn-white border bg-white shadow-sm btn-sm px-3 py-2 fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>
        </header>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                    <div class="card-body p-4 p-md-5">
                        <form action="/admin/categories" method="POST" enctype="multipart/form-data">
                            <div class="row g-4">

                                <div class="col-md-7">
                                    <div class="mb-4">
                                        <label for="name"
                                            class="form-label small fw-bold text-muted text-uppercase">Category
                                            Name</label>
                                        <input type="text"
                                            class="form-control form-control-lg shadow-none <%= (typeof errors !== 'undefined' && errors.name) ? 'is-invalid' : '' %>"
                                            name="name" id="name" placeholder="e.g. Premium Electronics"
                                            value="<%= (typeof oldData !== 'undefined') ? oldData.name : '' %>">

                                        <% if (locals.errors?.name) { %>
                                            <div class="invalid-feedback">
                                                <%= errors.name.msg %>
                                            </div>
                                            <% } %>
                                    </div>

                                    <div class="mb-4">
                                        <label for="description"
                                            class="form-label small fw-bold text-muted text-uppercase">Description</label>
                                        <textarea class="form-control shadow-none" id="description" name="description"
                                            rows="6"
                                            placeholder="Provide a brief summary of this category..."><%= (typeof oldData !== 'undefined') ? oldData.description : '' %></textarea>

                                        <% if (locals.errors?.description) { %>
                                            <div class="invalid-feedback">
                                                <%= errors.description.msg %>
                                            </div>
                                            <% } %>
                                    </div>

                                    <div class="mb-4">
                                        <div class="form-check form-switch custom-switch">
                                            <input class="form-check-input" type="checkbox" id="is_active"
                                                name="is_active" checked>
                                            <label class="form-check-label fw-semibold ms-2" for="is_active">Visibility:
                                                Visible on Storefront</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-5">
                                    <label class="form-label small fw-bold text-muted text-uppercase">Category Cover
                                        Image</label>
                                    <div class="image-upload-wrapper border-dashed rounded-4 p-4 text-center bg-light mb-3"
                                        style="border: 2px dashed #e2e8f0;">
                                        <div id="preview-container" class="mb-3 d-none">
                                            <img id="image-preview" src="#" alt="Preview"
                                                class="img-fluid rounded-3 shadow-sm"
                                                style="max-height: 200px; width: 100%; object-fit: cover;">
                                        </div>
                                        <div id="upload-placeholder">
                                            <i class="bi bi-cloud-arrow-up fs-1 text-muted"></i>
                                            <p class="small text-muted mt-2">Click to upload or drag and drop<br>PNG,
                                                JPG up to 2MB</p>
                                        </div>
                                        <input type="file" name="image" id="imageInput"
                                            class="form-control mt-2 shadow-none border-0 bg-transparent"
                                            accept="image/*" >

                                    </div>
                                    <% if (locals.errors?.image && errors.image.msg) { %>
                                        <div class="text-danger small mt-1">
                                            <%= errors.image.msg %>
                                        </div>
                                        <% } %>
                                </div>

                                <div class="col-12 border-top pt-4 mt-4 text-end">
                                    <button type="reset"
                                        class="btn btn-white border px-4 py-2 me-2 fw-semibold">Reset</button>
                                    <button type="submit" class="btn btn-primary px-5 py-2 fw-semibold shadow-sm">
                                        Publish Category
                                    </button>
                                </div>

                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        const imageInput = document.getElementById('imageInput');
        const previewContainer = document.getElementById('preview-container');
        const imagePreview = document.getElementById('image-preview');
        const placeholder = document.getElementById('upload-placeholder');

        imageInput.onchange = evt => {
            const [file] = imageInput.files;
            if (file) {
                imagePreview.src = URL.createObjectURL(file);
                previewContainer.classList.remove('d-none');
                placeholder.classList.add('d-none');
            }
        }
    </script>

    <%- include('../partials/header') %>