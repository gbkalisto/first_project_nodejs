<%- include('../partials/header') %>
    <div class="container py-5">

        <div class="row align-items-center mb-5">
            <div class="col">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/dashboard" class="text-decoration-none small">Home</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">Profile</li>
                    </ol>
                </nav>
                <h2 class="fw-bold">Update Profile</h2>
            </div>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-lg-8">
                <div class="card custom-card bg-white p-4 p-md-5">
                    <div class="mb-4">
                        <h4 class="fw-bold text-dark">Personal Information</h4>
                        <p class="text-muted small">Update your account details and profile picture.</p>
                    </div>

                    <form action="/admin/profile?_method=PUT" method="POST" enctype="multipart/form-data"
                        class="needs-validation">
                        <div class="row g-3">

                            <div class="col-12 text-center mb-4">
                                <div class="position-relative d-inline-block">

                                    <% if (admin.image) { %>
                                        <img src="/<%= admin.image %>" alt="Profile Preview"
                                            class="rounded-circle img-thumbnail shadow-sm"
                                            style="width: 120px; height: 120px; object-fit: cover;">
                                        <% } else { %>
                                            <div class="rounded-circle img-thumbnail shadow-sm d-flex align-items-center justify-content-center bg-light mx-auto"
                                                style="width: 120px; height: 120px;">
                                                <i class="bi bi-person-circle text-secondary"
                                                    style="font-size: 4rem;"></i>
                                            </div>
                                            <% } %>

                                                <div class="mt-3">
                                                    <label for="image"
                                                        class="form-label fw-semibold small text-uppercase">Change
                                                        Photo</label>
                                                    <input type="file" class="form-control form-control-sm" id="image"
                                                        name="image" accept="image/*">
                                                </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <label for="name" class="form-label fw-semibold small text-uppercase">Full Name</label>
                                <input type="text" class="form-control py-2 shadow-sm" id="name" name="name"
                                    value="<%= admin.name %>" required>
                            </div>

                            <div class="col-12">
                                <label for="email" class="form-label fw-semibold small text-uppercase">Email
                                    Address</label>
                                <input type="email" class="form-control py-2 shadow-sm" id="email" name="email"
                                    value="<%= admin.email %>" required>
                            </div>

                            <div class="col-12">
                                <label for="password" class="form-label fw-semibold small text-uppercase">New
                                    Password</label>
                                <input type="password" class="form-control py-2 shadow-sm" id="passwordpassword"
                                    name="password" placeholder="Leave blank to keep current password">
                                <small class="text-muted">Security tip: Use at least 8 characters.</small>
                            </div>

                            <div class="col-12 mt-4">
                                <hr class="text-muted opacity-25 mb-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="reset"
                                        class="btn btn-light px-4 py-2 fw-medium border">Cancel</button>
                                    <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm">
                                        <i class="bi bi-save me-2"></i>Save Changes
                                    </button>
                                </div>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/footer') %>