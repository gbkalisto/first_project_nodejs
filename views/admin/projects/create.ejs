<%- include('../partials/header') %>

    <main class="main-content">
        <header class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item small"><a href="/admin/dashboard"
                                class="text-decoration-none text-muted">Console</a></li>
                        <li class="breadcrumb-item small"><a href="/admin/projects"
                                class="text-decoration-none text-muted">Portfolio</a></li>
                        <li class="breadcrumb-item small active">Add Project</li>
                    </ol>
                </nav>
                <h2 class="fw-bold tracking-tight">Add Portfolio Project</h2>
            </div>
            <div>
                <a href="/admin/projects" class="btn btn-white border bg-white shadow-sm btn-sm px-3 py-2 fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i> Back to Gallery
                </a>
            </div>
        </header>

        <form action="/admin/projects" method="POST" enctype="multipart/form-data">
            <div class="row g-4">

                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Project Details</h5>

                            <div class="mb-4">
                                <label for="title" class="form-label small fw-bold text-muted text-uppercase">Project
                                    Title</label>
                                <input type="text"
                                    class="form-control form-control-lg shadow-none <%= (typeof errors !== 'undefined' && errors.title) ? 'is-invalid' : '' %>"
                                    name="title" id="title" placeholder="e.g. E-commerce Dashboard"
                                    value="<%= (typeof oldData !== 'undefined') ? oldData.title : '' %>">
                                <% if (typeof errors !=='undefined' && errors.title) { %>
                                    <div class="invalid-feedback">
                                        <%= errors.title %>
                                    </div>
                                    <% } %>
                            </div>

                            <div class="mb-0">
                                <label for="description"
                                    class="form-label small fw-bold text-muted text-uppercase">Project
                                    Description</label>
                                <textarea
                                    class="form-control shadow-none <%= (typeof errors !== 'undefined' && errors.description) ? 'is-invalid' : '' %>"
                                    id="description" name="description" rows="6"
                                    placeholder="Explain the project goals and your role..."><%= (typeof oldData !== 'undefined') ? oldData.description : '' %></textarea>
                                <% if (typeof errors !=='undefined' && errors.description) { %>
                                    <div class="text-danger small mt-1">
                                        <%= errors.description %>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Project Gallery (Screenshots)</h5>
                            <div class="p-4 border rounded-4 bg-light">
                                <label class="form-label small fw-bold text-muted text-uppercase">Upload Multiple
                                    Images</label>
                                <input type="file" name="screenshots" class="form-control shadow-none" accept="image/*"
                                    multiple>
                                <p class="text-muted small mt-2 mb-0"><i class="bi bi-info-circle me-1"></i> You can
                                    select up to 5 images showcasing the project UI.</p>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm mt-4" style="border-radius: 16px;">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Visibility Status</h5>

                            <div
                                class="d-flex align-items-center justify-content-between p-3 border rounded-4 bg-light">
                                <div>
                                    <span class="fw-bold small text-uppercase d-block">Project Status</span>
                                    <small class="text-muted">Control public visibility</small>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input shadow-none" type="checkbox" role="switch"
                                        id="statusSwitch" name="status" value="active"
                                        style="width: 2.5em; height: 1.25em;" <%=(typeof oldData !=='undefined' &&
                                        oldData.status==='active' ) || typeof oldData==='undefined' ? 'checked' : '' %>>
                                </div>
                            </div>

                            <div class="mt-3">
                                <span id="statusLabel"
                                    class="badge rounded-pill <%= (typeof oldData !== 'undefined' && oldData.status === 'inactive') ? 'bg-secondary' : 'bg-success' %> px-3">
                                    <%= (typeof oldData !=='undefined' && oldData.status==='inactive' ) ? 'Inactive'
                                        : 'Active' %>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Cover Image</h5>
                            <div class="image-upload-wrapper border-dashed rounded-4 p-3 text-center bg-light"
                                style="border: 2px dashed #cbd5e1;">
                                <div id="preview-container" class="mb-3 d-none">
                                    <img id="image-preview" src="#" alt="Preview" class="img-fluid rounded-3 shadow-sm"
                                        style="max-height: 150px;">
                                </div>
                                <div id="upload-placeholder">
                                    <i class="bi bi-image fs-2 text-muted"></i>
                                    <p class="small text-muted mt-2">Main Display Photo</p>
                                </div>
                                <input type="file" name="coverImage" id="imageInput"
                                    class="form-control form-control-sm mt-2 shadow-none" accept="image/*">
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Meta Data</h5>

                            <div class="mb-4">
                                <label for="liveUrl" class="form-label small fw-bold text-muted text-uppercase">Live
                                    Demo URL</label>
                                <input type="url" class="form-control shadow-none" name="liveUrl" id="liveUrl"
                                    placeholder="https://example.com"
                                    value="<%= (typeof oldData !== 'undefined') ? oldData.liveUrl : '' %>">
                            </div>

                            <div class="mb-0">
                                <label class="form-label small fw-bold text-muted text-uppercase">Tech Stack</label>
                                <div class="row g-2">
                                    <% ['Node.js', 'React' , 'MongoDB' , 'Express', 'Laravel','Java', 'Bootstrap','Html 5' ].forEach(tech=> { %>
                                        <div class="col-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="techStack"
                                                    value="<%= tech %>" id="check<%= tech %>" <%=(typeof oldData
                                                    !=='undefined' && oldData.techStack &&
                                                    oldData.techStack.includes(tech)) ? 'checked' : '' %>>
                                                <label class="form-check-label small" for="check<%= tech %>">
                                                    <%= tech %>
                                                </label>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary py-3 fw-bold shadow-sm">
                            <i class="bi bi-cloud-arrow-up me-2"></i> Save Project
                        </button>
                        <a href="/admin/projects" class="btn btn-white border py-2 small fw-semibold">Cancel</a>
                    </div>
                </div>

            </div>
        </form>
    </main>

    <script>
        // Preview for Single Cover Image
        const imageInput = document.getElementById('imageInput');
        const previewContainer = document.getElementById('preview-container');
        const imagePreview = document.getElementById('image-preview');
        const placeholder = document.getElementById('upload-placeholder');

        imageInput.onchange = evt => {
            const [file] = imageInput.files;
            if (file) {
                imagePreview.src = URL.createObjectURL(file);
                previewContainer.classList.remove('d-none');
                placeholder.classList.add('d-none');
            }
        }
    </script>

    <%- include('../partials/footer') %>