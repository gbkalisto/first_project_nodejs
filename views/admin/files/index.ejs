<%- include('../partials/header') %>

    <style>
        .x-small {
            font-size: 0.65rem;
        }

        .object-fit-cover {
            object-fit: cover;
        }

        /* Action Bar Animation */
        .action-bar {
            background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
            transform: translateY(100%);
            transition: transform 0.3s ease-in-out;
            z-index: 10;
        }

        .media-card:hover .action-bar {
            transform: translateY(0);
        }

        /* Glass Button Styling */
        .btn-white-glass {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(4px);
            border: none;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }

        .btn-white-glass:hover {
            background: #fff;
            transform: scale(1.15);
            color: inherit;
        }

        /* Card Lift Effect */
        .media-card {
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .media-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1) !important;
        }

        .ratio-1x1 {
            --bs-aspect-ratio: 100%;
        }
  
        /* 1. Base state of the image (Blurry & Transparent) */
        .lazy-img {
            filter: blur(10px);
            opacity: 0;
            transition: filter 0.6s ease-in-out, opacity 0.5s ease-in-out;
            background-color: #f0f0f0;
            /* Placeholder color while loading */
        }

        /* 2. Loaded state (Triggered by the onload JS in the HTML) */
        .lazy-img.loaded {
            filter: blur(0);
            opacity: 1;
        }

        /* Optional: Add a subtle pulse animation to the background while loading */
        .ratio.bg-light {
            background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
            background-size: 200% 100%;
            animation: loading-pulse 1.5s infinite;
        }

        @keyframes loading-pulse {
            0% {
                background-position: 200% 0;
            }

            100% {
                background-position: -200% 0;
            }
        }

        /* ... keep your previous action-bar and media-card styles ... */
    </style>

    <main class="main-content">
        <header class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item small"><a href="/admin/dashboard"
                                class="text-decoration-none text-muted">Console</a></li>
                        <li class="breadcrumb-item small active">Media</li>
                    </ol>
                </nav>
                <h2 class="fw-bold tracking-tight">Media Summary</h2>
            </div>
            <div>
                <a href="/admin/media/create" class="btn btn-primary shadow-sm px-4 py-2 fw-bold">
                    <i class="bi bi-plus-lg me-2"></i> Upload New Photo
                </a>
            </div>
        </header>

        <%- include('../partials/flashmsg') %>

            <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
                <div class="card-header bg-white border-0 p-4">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-4">
                            <h5 class="fw-bold mb-0">Manage Media</h5>
                        </div>
                        <div class="col-md-8">
                            <form action="">
                                <div class="d-flex gap-2 justify-content-md-end">
                                    <div class="input-group input-group-sm w-50">
                                        <span class="input-group-text bg-light border-0"><i
                                                class="bi bi-search"></i></span>
                                        <input type="search" name="search" class="form-control bg-light border-0"
                                            placeholder="Search posts..." value="">
                                    </div>
                                    <button type="submit" class="btn btn-light btn-sm border text-muted"><i
                                            class="bi bi-filter"></i></button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>

                <div class="card-body p-4 bg-light-subtle">
                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                        <% files.forEach(function(file){ %>
                            <div class="col">
                                <div class="card h-100 border-0 shadow-sm position-relative media-card"
                                    style="border-radius: 12px; overflow: hidden; background: #fff;">

                                    <div class="ratio ratio-1x1 bg-light container-overlay">
                                        <img src="/<%= file.image %>" class="card-img-top object-fit-cover lazy-img"
                                            loading="lazy" onload="this.classList.add('loaded')" alt="Media content">

                                        <div class="position-absolute top-0 start-0 p-2" style="z-index: 2;">
                                            <span class="badge bg-dark bg-opacity-50 x-small text-uppercase">
                                                #<%= file._id.toString().substring(18) %>
                                            </span>
                                        </div>

                                        <div
                                            class="action-bar position-absolute bottom-0 start-0 w-100 d-flex justify-content-center align-items-center gap-3 py-3">
                                            <a href="/<%= file.image %>" target="_blank"
                                                class="btn btn-white-glass btn-icon rounded-circle shadow"
                                                title="Preview">
                                                <i class="bi bi-eye text-dark"></i>
                                            </a>

                                            <!-- <a href="/admin/posts/edit/<%= file._id %>"
                                                class="btn btn-white-glass btn-icon rounded-circle shadow" title="Edit">
                                                <i class="bi bi-pencil text-primary"></i>
                                            </a> -->

                                            <form action="/admin/media/delete/<%= file._id %>?_method=DELETE" method="POST"
                                                onsubmit="return confirm('Delete this image?')" class="m-0">
                                                <button type="submit"
                                                    class="btn btn-white-glass btn-icon rounded-circle shadow"
                                                    title="Delete">
                                                    <i class="bi bi-trash3 text-danger"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                </div>
            </div>
    </main>


    <%- include('../partials/footer') %>