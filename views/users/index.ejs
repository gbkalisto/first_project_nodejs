<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile Card</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container mt-5">
        <div class="row">
            <p class="my-2"><a href="/users/create">Add Users</a></p>

            <% users.forEach(function(user){ %>
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <img src="<%= user.image %>" class="card-img-top" alt="User Image"
                            style="height: 300px; object-fit: cover;">

                        <div class="card-body">
                            <h5 class="card-title">
                                <%= user.name %>
                            </h5>
                            <p class="card-text text-muted mb-4">
                                <%= user.email %>
                            </p>

                            <div class="d-flex gap-2">
                                <a href="users/<%= user._id %>/edit" type="button"
                                    class="btn btn-primary w-100">Edit</a>
                                <a href="users/delete/<%= user._id %>" type="button"
                                    class="btn btn-outline-danger w-100">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>