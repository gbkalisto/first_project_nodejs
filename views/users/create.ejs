<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile Card</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <div
                            class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <h4 class="mb-0">Add New User</h4>
                            <a href="/users" class="btn btn-sm btn-light text-primary">← Back to List</a>
                        </div>
                    </div>
                    <div class="card-body">
                        <form action="/users" method="POST" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label for="name" class="form-label">Full Name</label>
                                <input type="text" name="name"
                                    class="form-control <%= (typeof errors !== 'undefined' && errors.name) ? 'is-invalid' : '' %>"
                                    id="name" placeholder="Enter name"
                                    value="<%= (typeof oldData !== 'undefined') ? oldData.name : '' %>">
                                <% if (typeof errors !=='undefined' && errors.name) { %>
                                    <div class="invalid-feedback">
                                        <%= errors.name %>
                                    </div>
                                    <% } %>
                            </div>

                            <div class="mb-3">
                                <label for="email" class="form-label">Email Address</label>
                                <input type="email" name="email"
                                    class="form-control <%= (typeof errors !== 'undefined' && errors.email) ? 'is-invalid' : '' %>"
                                    id="email" placeholder="name@example.com"
                                    value="<%= (typeof oldData !== 'undefined') ? oldData.name : '' %>">
                                <% if (typeof errors !=='undefined' && errors.email) { %>
                                    <div class="invalid-feedback">
                                        <%= errors.email %>
                                    </div>
                                    <% } %>
                            </div>

                            <div class="mb-3">
                                <label for="image_url" class="form-label">Image </label>
                                <input type="file" name="image" class="form-control" id="image_url"
                                    placeholder="https://image-link.com/photo.jpg">
                            </div>
                            <div class="mb-3">
                                <label for="image_url" class="form-label">Password </label>
                                <input type="password" name="password"
                                    class="form-control <%= (typeof errors !== 'undefined' && errors.email) ? 'is-invalid' : '' %>"
                                    id="password" placeholder="********"
                                    value="<%= (typeof oldData !== 'undefined') ? oldData.password : '' %>">
                                <% if (typeof errors !=='undefined' && errors.password) { %>
                                    <div class="invalid-feedback">
                                        <%= errors.password %>
                                    </div>
                                    <% } %>
                            </div>

                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-success btn-lg">Save User</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>