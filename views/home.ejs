<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="icon" type="image/svg+xml"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='%230d6efd' class='bi bi-stack' viewBox='0 0 16 16'><path d='m14.12 10.163 1.715.858c.22.11.22.424 0 .534L8.267 15.34a.6.6 0 0 1-.534 0L.165 11.555a.299.299 0 0 1 0-.534l1.716-.858 5.317 2.659c.505.252 1.1.252 1.604 0l5.317-2.66zM7.733.063a.6.6 0 0 1 .534 0l7.568 3.784a.3.3 0 0 1 0 .535L8.267 8.165a.6.6 0 0 1-.534 0L.165 4.382a.299.299 0 0 1 0-.535z'/><path d='m14.12 6.576 1.715.858c.22.11.22.424 0 .534l-7.568 3.784a.6.6 0 0 1-.534 0L.165 7.968a.299.299 0 0 1 0-.534l1.716-.858 5.317 2.659c.505.252 1.1.252 1.604 0z'/></svg>">
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">MyStore</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/register">Sign Up</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Sign In</a>
                    </li>
                </ul>
            </div> -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">

                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="nav-link active" href="/"><%= user.name %></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold text-primary" href="/dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger" href="/logout">Logout</a>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/register">Sign Up</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/login">Sign In</a>
                            </li>
                            <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- <div class="container mt-5 text-center">
        <h1>Welcome to the Home page </h1>
        <p class="lead">Use the navigation above to manage your users and products.</p>
    </div> -->
    <div class="container mt-5">
        <div class="row mb-4 align-items-center">
            <div class="col">
                <h1 class="fw-bold">Latest Stories</h1>
                <p class="text-muted">Explore the latest insights from our community.</p>
            </div>
        </div>

        <div class="row g-4">
            <% if (posts.length> 0) { %>
                <% posts.forEach(post=> { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden transition-hover">
                            <div class="bg-primary bg-gradient py-5 text-center text-white">
                                <i class="bi bi-file-text display-4"></i>
                            </div>

                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <span
                                        class="badge bg-light text-primary border border-primary-subtle rounded-pill px-3">
                                        <i class="bi bi-person me-1"></i>
                                        <%= post.author ? post.author.name : 'Guest' %>
                                    </span>
                                    <small class="text-muted ms-auto">
                                        <%= new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short' ,
                                            day: 'numeric' }) %>
                                    </small>
                                </div>

                                <h5 class="card-title fw-bold mb-3">
                                    <%= post.title %>
                                </h5>

                                <p class="card-text text-muted small">
                                    <%= post.body.substring(0, 120) %>...
                                </p>
                            </div>

                            <div class="card-footer bg-white border-0 p-4 pt-0">
                                <a href="/posts/<%= post.slug %>"
                                    class="btn btn-outline-primary w-100 rounded-pill fw-semibold">
                                    Read More
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="col-12 text-center py-5">
                                <i class="bi bi-journal-x display-1 text-light"></i>
                                <h3 class="mt-3 text-muted">No posts found</h3>
                                <a href="/dashboard" class="btn btn-primary mt-2">Go to Dashboard</a>
                            </div>
                            <% } %>
        </div>
    </div>

    <style>
        .transition-hover {
            transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
        }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>